<?xml version="1.0" encoding="utf-8"?>
<!-- Simplified habit card with "Last 7 Days" circle layout (no complex grid) -->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/spacing_micro"
    android:layout_marginVertical="@dimen/spacing_micro"
    app:cardCornerRadius="@dimen/corner_subtle"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/surface_dark"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/spacing_standard">

        <!-- Habit title -->
        <TextView
            android:id="@+id/habitTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_body"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            tools:text="🏃 Exercise regularly"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Frequency subtitle -->
        <TextView
            android:id="@+id/habitFrequency"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textSize="@dimen/text_caption"
            android:textColor="@color/text_tertiary"
            tools:text="Daily"
            app:layout_constraintTop_toBottomOf="@id/habitTitle"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Last 7 Days circles (horizontal LinearLayout) -->
        <LinearLayout
            android:id="@+id/last7DaysContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_standard"
            android:orientation="horizontal"
            android:gravity="start"
            app:layout_constraintTop_toBottomOf="@id/habitFrequency"
            app:layout_constraintStart_toStartOf="parent">
            
            <!-- 7 circles will be added programmatically -->
            
        </LinearLayout>

        <!-- Streak/stats text -->
        <TextView
            android:id="@+id/statsText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_micro"
            android:textSize="@dimen/text_caption"
            android:textColor="@color/text_tertiary"
            tools:text="5 day streak 🔥"
            app:layout_constraintTop_toBottomOf="@id/last7DaysContainer"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Check-in button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/checkInButton"
            style="@style/Widget.Material3.Button"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginTop="@dimen/spacing_standard"
            android:text="+ Check In"
            android:textSize="@dimen/text_body_small"
            app:cornerRadius="@dimen/corner_pill_small"
            app:backgroundTint="@color/accent_sage"
            app:layout_constraintTop_toBottomOf="@id/statsText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
