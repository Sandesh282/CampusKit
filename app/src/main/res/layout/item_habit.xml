<?xml version="1.0" encoding="utf-8"?>
<!-- Habit card with grid-based progress visualization (Reference 2 inspired) -->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/spacing_micro"
    android:layout_marginVertical="@dimen/spacing_micro"
    app:cardCornerRadius="@dimen/corner_subtle"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/surface_dark"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/spacing_standard">

        <!-- Habit title and emoji/icon -->
        <TextView
            android:id="@+id/habitIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            tools:text="🏃"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/habitTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_tight"
            android:textSize="@dimen/text_body"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            tools:text="Exercise regularly"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/habitIcon"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Subtitle/description -->
        <TextView
            android:id="@+id/habitSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:layout_marginStart="@dimen/spacing_tight"
            android:textSize="@dimen/text_caption"
            android:textColor="@color/text_tertiary"
            tools:text="Build routines that lead to success"
            app:layout_constraintTop_toBottomOf="@id/habitTitle"
            app:layout_constraintStart_toEndOf="@id/habitIcon"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Grid-based progress visualization (GitHub-style contribution grid) -->
        <com.example.campuskit.ui.view.HabitProgressGridView
            android:id="@+id/progressGrid"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_standard"
            app:layout_constraintTop_toBottomOf="@id/habitSubtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/statsContainer"
            app:layout_constraintWidth_percent="0.6" />

        <!-- Stats container (check-in progress, streak) -->
        <LinearLayout
            android:id="@+id/statsContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_standard"
            android:layout_marginTop="@dimen/spacing_standard"
            android:orientation="vertical"
            android:gravity="end"
            app:layout_constraintTop_toBottomOf="@id/habitSubtitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/progressGrid">

            <!-- Weekly progress dots -->
            <LinearLayout
                android:id="@+id/weeklyProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end">
                
                <!-- Dots added programmatically -->
            </LinearLayout>

            <!-- Current streak or stats -->
            <TextView
                android:id="@+id/statsText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_micro"
                android:textSize="@dimen/text_caption"
                android:textColor="@color/text_tertiary"
                android:gravity="end"
                tools:text="5 day streak" />

        </LinearLayout>

        <!-- Check-in button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/checkInButton"
            style="@style/Widget.Material3.Button"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginTop="@dimen/spacing_standard"
            android:text="+ Check In"
            android:textSize="@dimen/text_body_small"
            app:cornerRadius="@dimen/corner_pill_small"
            app:backgroundTint="@color/accent_sage"
            app:layout_constraintTop_toBottomOf="@id/progressGrid"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
