<?xml version="1.0" encoding="utf-8"?>
<!-- Timeline task card with "Two-Line Logic" for continuous vertical timeline -->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="0dp"
    android:layout_marginVertical="@dimen/spacing_micro"
    app:cardCornerRadius="@dimen/corner_card"
    app:cardElevation="@dimen/elevation_card"
    app:cardBackgroundColor="@color/surface_dark"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/spacing_standard">

        <!-- TOP LINE VIEW (connects to previous card) -->
        <View
            android:id="@+id/topLine"
            android:layout_width="2dp"
            android:layout_height="0dp"
            android:background="@color/accent_primary"
            android:alpha="0.3"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/taskIcon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/taskTitle"
            app:layout_constraintHorizontal_bias="0.15" />

        <!-- ICON/MARKER (center of timeline) -->
        <View
            android:id="@+id/taskIcon"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/date_pill_selected"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- BOTTOM LINE VIEW (connects to next card) -->
        <View
            android:id="@+id/bottomLine"
            android:layout_width="2dp"
            android:layout_height="0dp"
            android:background="@color/accent_primary"
            android:alpha="0.3"
            app:layout_constraintTop_toBottomOf="@id/taskIcon"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/taskTitle"
            app:layout_constraintHorizontal_bias="0.15" />

        <!-- Time label (subtle, secondary) -->
        <TextView
            android:id="@+id/taskTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_standard"
            android:textSize="@dimen/text_caption"
            android:textColor="@color/text_tertiary"
            tools:text="08:00"
            android:visibility="gone"
            tools:visibility="visible"
            app:layout_constraintTop_toTopOf="@id/taskIcon"
            app:layout_constraintBottom_toBottomOf="@id/taskIcon"
            app:layout_constraintStart_toEndOf="@id/taskIcon" />

        <!-- Task title -->
        <TextView
            android:id="@+id/taskTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_section"
            android:textSize="@dimen/text_body"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            tools:text="Morning Routine"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/taskIcon"
            app:layout_constraintEnd_toStartOf="@id/statusIndicator" />

        <!-- Status indicator (circular, right side) -->
        <View
            android:id="@+id/statusIndicator"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:background="@drawable/date_pill_unselected"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Task category/description -->
        <TextView
            android:id="@+id/taskDescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_micro"
            android:layout_marginStart="@dimen/spacing_section"
            android:textSize="@dimen/text_body_small"
            android:textColor="@color/text_secondary"
            android:maxLines="2"
            android:ellipsize="end"
            tools:text="Health • Complete morning exercises"
            app:layout_constraintTop_toBottomOf="@id/taskTitle"
            app:layout_constraintStart_toEndOf="@id/taskIcon"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
