<?xml version="1.0" encoding="utf-8"?>
<!-- Date pill view - selected state with elevation and accent color -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Elevation shadow (subtle) -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#20000000" />
            <size
                android:width="@dimen/date_pill_small"
                android:height="@dimen/date_pill_small" />
        </shape>
    </item>
    
    <!-- Main pill background -->
    <item
        android:top="1dp"
        android:paddingBottom="3dp">
        <shape android:shape="oval">
            <solid android:color="@color/accent_sage" />
            <size
                android:width="@dimen/date_pill_small"
                android:height="@dimen/date_pill_small" />
        </shape>
    </item>
    
</layer-list>
